<%- include('partials/head.ejs', { pageTitle: 'Registered Homes' }) %>
    </head>

    <body class="bg-gray-50 min-h-screen">
        <%- include('partials/nav.ejs') %>

            <!-- Main Content Section -->
            <main class="container mx-auto shadow-xl rounded-2xl p-8 mt-10 max-w-4xl bg-white border border-gray-100">
                <div class="text-center mb-10">
                    <h2 class="text-4xl text-gray-800 font-extrabold inline-block relative pb-3">
                        Registered Homes
                        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-1.5 bg-gradient-to-r from-red-400 via-pink-500 to-purple-500 rounded-full"></div>
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <% RegisteredHomes.forEach(home => { %>
                        <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.08)] hover:shadow-[0_8px_30px_-4px_rgba(0,0,0,0.15)] hover:-translate-y-1 transition-all duration-300 overflow-hidden group cursor-pointer flex flex-col">
                            <!-- Image/Gradient Placeholder -->
                            <div class="h-48 bg-gradient-to-br from-red-400 via-pink-500 to-purple-500 relative flex justify-center items-center overflow-hidden">
                                <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-300"></div>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white opacity-90 group-hover:scale-110 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                <!-- Floating Price Badge -->
                                <div class="absolute bottom-3 right-3 bg-white/95 backdrop-blur-sm px-3 py-1.5 rounded-full shadow-lg font-bold text-gray-900 border border-white/20">
                                    Rs <%= home.price %> <span class="text-gray-500 font-normal text-xs">/ night</span>
                                </div>
                            </div>
                            
                            <!-- Content Details -->
                            <div class="p-6 flex-1 flex flex-col">
                                <div class="flex justify-between items-start mb-3">
                                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-pink-600 transition-colors line-clamp-1 pr-2" title="<%= home.houseName %>">
                                        <%= home.houseName %>
                                    </h3>
                                    
                                    <div class="flex items-center space-x-1 bg-yellow-50 text-yellow-700 px-2 py-1 rounded-md text-sm font-medium shrink-0 border border-yellow-200/50">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-yellow-500">
                                            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                                        </svg>
                                        <span><%= home.rating %></span>
                                    </div>
                                </div>
                                
                                <div class="mt-auto pt-4 border-t border-gray-100">
                                    <p class="text-gray-500 text-sm flex items-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-2 text-pink-500">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                                        </svg>
                                        <%= home.location %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Empty State -->
                <% if (RegisteredHomes.length === 0) { %>
                    <div class="flex flex-col items-center justify-center p-12 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        <h3 class="text-xl font-medium text-gray-900 mb-1">No homes available</h3>
                        <p class="text-gray-500 text-center">There are no homes registered yet. Check back later!</p>
                    </div>
                <% } %>
            </main>


    </body>

    </html>